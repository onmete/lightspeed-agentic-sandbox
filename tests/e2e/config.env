OPENAI_MODEL=gpt-4.1-mini
DEEPAGENTS_MODEL=claude-haiku-3-5
DEEPAGENTS_GEMINI_MODEL=gemini-2.5-flash
DEEPAGENTS_OPENAI_MODEL=gpt-4.1-mini
